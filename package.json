{
  "name": "agentroom",
  "version": "0.1.0",
  "description": "Local-first shared understanding layer for AI-coded projects.",
  "type": "module",
  "bin": {
    "agentroom": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "agentroom-plan-complet.md"
  ],
  "scripts": {
    "dev": "tsx src/cli.ts --no-open",
    "connect": "tsx src/cli.ts connect",
    "mcp": "tsx src/cli.ts mcp",
    "build": "tsc -p tsconfig.build.json && vite build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --config vitest.config.ts",
    "lint": "eslint . --ext .ts,.tsx",
    "preview": "tsx src/cli.ts --no-open"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@vitejs/plugin-react": "^6.0.2",
    "better-sqlite3": "^12.11.1",
    "commander": "^14.0.2",
    "express": "^5.2.1",
    "lucide-react": "^0.561.0",
    "minimatch": "^10.1.1",
    "open": "^10.2.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "ws": "^8.18.3",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "eslint": "^9.39.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.50.0",
    "vite": "^8.0.16",
    "vitest": "^4.0.16"
  },
  "engines": {
    "node": ">=20.11"
  }
}
